# ============================================================
# MAXD Dashboard — Environment Variables
#
# Copy this file to .env.local for local development.
# Set all variables in Vercel → Settings → Environment Variables
# for production.
#
# VITE_ prefix = baked into the frontend build (safe to expose)
# No prefix    = server-side only (Vercel Functions, never browser)
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic — AI Studio (required for AI features) ─────────
# Found in: console.anthropic.com → API Keys → Create Key
# NEVER use VITE_ prefix — this key must stay server-side only
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe (future — not active yet) ─────────────────────────
# Found in: dashboard.stripe.com → Developers → API keys
# STRIPE_SECRET_KEY=sk_live_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
