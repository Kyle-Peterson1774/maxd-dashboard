# ============================================
# MAXD DASHBOARD — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub
# ============================================

# --- Shopify ---
VITE_SHOPIFY_STORE_URL=your-store.myshopify.com
VITE_SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# --- Anthropic (Claude API) ---
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Google ---
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GOOGLE_CLOUD_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXX

# --- Klaviyo ---
VITE_KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxx

# --- Firebase (Auth + Role-based access) ---
VITE_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# --- Make (Automation webhooks) ---
VITE_MAKE_WEBHOOK_CONTENT=https://hook.make.com/xxxxxxxx
VITE_MAKE_WEBHOOK_DIGEST=https://hook.make.com/xxxxxxxx
